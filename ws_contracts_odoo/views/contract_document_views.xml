<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Contract Document: Kanban ═══ -->
    <record id="ws_contract_document_kanban" model="ir.ui.view">
        <field name="name">ws.contract.document.kanban</field>
        <field name="model">ws.contract.document</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile"
                    quick_create="false">
                <field name="state"/>
                <field name="employee_id"/>
                <field name="template_id"/>
                <field name="doc_type"/>
                <field name="generated_date"/>
                <field name="signed_date"/>
                <field name="company_id"/>
                <progressbar field="state"
                             colors='{"draft": "muted", "generated": "danger", "sent_for_sign": "warning", "signed": "success", "archived": "200"}'/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <strong><field name="employee_id"/></strong>
                            <field name="doc_type" widget="badge"/>
                        </div>
                        <div class="text-muted">
                            <field name="template_id"/>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <span t-if="record.generated_date.raw_value" class="text-muted">
                                <i class="fa fa-calendar"/> <field name="generated_date"/>
                            </span>
                            <span t-if="record.signed_date.raw_value" class="text-success">
                                <i class="fa fa-check"/> <field name="signed_date"/>
                            </span>
                        </div>
                        <footer>
                            <field name="company_id" class="float-end"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Contract Document: Tree ═══ -->
    <record id="ws_contract_document_tree" model="ir.ui.view">
        <field name="name">ws.contract.document.tree</field>
        <field name="model">ws.contract.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'generated'">
                <field name="employee_id"/>
                <field name="template_id"/>
                <field name="doc_type"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'signed'"
                       decoration-warning="state == 'sent_for_sign'"
                       decoration-danger="state == 'generated'"
                       decoration-muted="state == 'archived'"/>
                <field name="generated_date"/>
                <field name="signed_date"/>
                <field name="signing_date" optional="hide"/>
                <field name="contract_start_date" optional="hide"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!-- ═══ Contract Document: Form ═══ -->
    <record id="ws_contract_document_form" model="ir.ui.view">
        <field name="name">ws.contract.document.form</field>
        <field name="model">ws.contract.document</field>
        <field name="arch" type="xml">
            <form string="Contract Document">
                <header>
                    <button name="action_generate" type="object"
                            string="Generate PDF" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_send_for_signature" type="object"
                            string="Send for Signature" class="oe_highlight"
                            invisible="state != 'generated'"/>
                    <button name="action_mark_signed" type="object"
                            string="Mark as Signed"
                            invisible="state != 'sent_for_sign'"
                            confirm="Mark this document as signed?"/>
                    <button name="action_move_to_archive" type="object"
                            string="Archive"
                            invisible="state in ('archived', 'draft')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,generated,sent_for_sign,signed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="template_id"
                                   domain="[('company_id', '=', company_id)]"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="doc_type"/>
                            <field name="generated_date"/>
                            <field name="signed_date"/>
                            <field name="pdf_attachment_id"/>
                            <field name="sign_request_id" invisible="sign_request_id == 0"/>
                        </group>
                    </group>
                    <group string="Contract Details"
                           invisible="not template_id or doc_type not in ('probna_1m','probna_2m','probna_3m','probna_2plus1','zlecenie','czas_okreslony','czas_nieokreslony')">
                        <group string="Dates">
                            <field name="signing_date"/>
                            <field name="contract_start_date"/>
                            <field name="contract_end_date"
                                   invisible="doc_type == 'czas_nieokreslony'"/>
                        </group>
                        <group string="Position">
                            <field name="job_title_pl"/>
                            <field name="job_title_en"/>
                            <field name="place_of_work"/>
                        </group>
                    </group>
                    <group invisible="not template_id or doc_type not in ('probna_1m','probna_2m','probna_3m','probna_2plus1','zlecenie','czas_okreslony','czas_nieokreslony')">
                        <group string="Employment Terms"
                               invisible="doc_type == 'zlecenie'">
                            <field name="working_time_pl"/>
                            <field name="working_time_en"/>
                            <field name="salary_gross"/>
                        </group>
                        <group string="Mandate Terms"
                               invisible="doc_type != 'zlecenie'">
                            <field name="hourly_rate_gross"/>
                            <field name="scope_of_work_pl"/>
                            <field name="scope_of_work_en"/>
                            <field name="id_document_pl"/>
                            <field name="id_document_en"/>
                        </group>
                    </group>
                    <group invisible="doc_type != 'probna_2plus1'">
                        <group string="Extension Justification">
                            <field name="justification_pl"/>
                            <field name="justification_en"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ Contract Document: Search ═══ -->
    <record id="ws_contract_document_search" model="ir.ui.view">
        <field name="name">ws.contract.document.search</field>
        <field name="model">ws.contract.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="template_id"/>
                <filter name="not_archived" string="Active"
                        domain="[('state', '!=', 'archived')]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="generated" string="Generated" domain="[('state', '=', 'generated')]"/>
                <filter name="sent_for_sign" string="Sent for Signature" domain="[('state', '=', 'sent_for_sign')]"/>
                <filter name="signed" string="Signed" domain="[('state', '=', 'signed')]"/>
                <filter name="archived" string="Archived" domain="[('state', '=', 'archived')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                    <filter name="group_type" string="Document Type" context="{'group_by': 'doc_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ Contract Document: Action ═══ -->
    <record id="ws_contract_document_action" model="ir.actions.act_window">
        <field name="name">Contract Documents</field>
        <field name="res_model">ws.contract.document</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="ws_contract_document_search"/>
        <field name="context">{'search_default_not_archived': 1}</field>
    </record>

    <!-- ═══ Menu: Documents ═══ -->
    <menuitem id="ws_contracts_menu_documents"
              name="Documents"
              parent="ws_contracts_menu_root"
              action="ws_contract_document_action"
              sequence="10"/>

</odoo>
