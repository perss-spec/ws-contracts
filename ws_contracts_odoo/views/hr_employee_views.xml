<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend hr.employee form: add button + Contract Details tab + Documents tab -->
    <record id="view_employee_form_inherit_ws_contracts" model="ir.ui.view">
        <field name="name">hr.employee.form.ws.contracts</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Button in header -->
            <xpath expr="//header" position="inside">
                <button name="action_generate_documents"
                        string="Generate Documents"
                        type="object"
                        class="oe_highlight"
                        icon="fa-file-pdf-o"/>
            </xpath>

            <!-- Smart button: document count -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_contract_documents"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o">
                    <field name="ws_document_count" widget="statinfo" string="Documents"/>
                </button>
            </xpath>

            <!-- Contract Details tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Contract Details" name="ws_contract_details">
                    <group>
                        <group string="Personal (Latin)">
                            <field name="ws_full_name_lat"/>
                            <field name="ws_passport_number"/>
                            <field name="ws_passport_issued"/>
                            <field name="ws_passport_expires"/>
                            <field name="ws_address_full"/>
                        </group>
                        <group string="Bank Details">
                            <field name="ws_iban"/>
                            <field name="ws_swift"/>
                            <field name="ws_receiver_name"/>
                        </group>
                    </group>
                    <group>
                        <group string="Agreement">
                            <field name="ws_rate_usd"/>
                            <field name="ws_service_description"/>
                            <field name="ws_agreement_date"/>
                            <field name="ws_effective_date"/>
                        </group>
                    </group>
                </page>

                <!-- Documents tab -->
                <page string="Contracts &amp; Documents" name="ws_documents">
                    <field name="ws_document_ids">
                        <tree>
                            <field name="template_id"/>
                            <field name="doc_type"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-success="state == 'signed'"
                                   decoration-warning="state == 'sent_for_sign'"/>
                            <field name="generated_date"/>
                            <field name="signed_date"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
