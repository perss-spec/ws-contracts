<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Bulk Generate PDF ═══ -->
    <record id="action_bulk_generate_pdf" model="ir.actions.server">
        <field name="name">Generate PDF</field>
        <field name="model_id" ref="model_ws_contract_document"/>
        <field name="binding_model_id" ref="model_ws_contract_document"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_bulk_generate()</field>
    </record>

    <!-- ═══ Bulk Archive ═══ -->
    <record id="action_bulk_archive" model="ir.actions.server">
        <field name="name">Archive</field>
        <field name="model_id" ref="model_ws_contract_document"/>
        <field name="binding_model_id" ref="model_ws_contract_document"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_bulk_archive()</field>
    </record>

</odoo>
