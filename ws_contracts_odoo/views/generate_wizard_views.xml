<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_generate_wizard_form" model="ir.ui.view">
        <field name="name">ws.generate.wizard.form</field>
        <field name="model">ws.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Documents">

                <!-- Step 1: Choose -->
                <group invisible="state != 'choose'">
                    <group>
                        <field name="employee_id" readonly="1"/>
                        <field name="use_template"/>
                    </group>
                    <!-- Legacy mode -->
                    <group invisible="use_template">
                        <field name="doc_type"/>
                    </group>
                    <!-- Template mode -->
                    <group invisible="not use_template">
                        <field name="employee_company_id" invisible="1"/>
                        <field name="template_id"
                               required="use_template"
                               domain="[('company_id', '=', employee_company_id), ('active', '=', True)]"/>
                    </group>
                </group>

                <!-- Step 2: Download -->
                <group invisible="state != 'done'">
                    <div class="alert alert-success" role="alert">
                        Documents generated successfully!
                    </div>
                    <group>
                        <field name="nda_file" filename="nda_filename"
                               invisible="not nda_file"/>
                        <field name="nda_filename" invisible="1"/>
                        <field name="contract_file" filename="contract_filename"
                               invisible="not contract_file"/>
                        <field name="contract_filename" invisible="1"/>
                        <field name="docx_file" filename="docx_filename"
                               invisible="not docx_file"/>
                        <field name="docx_filename" invisible="1"/>
                    </group>
                </group>

                <field name="state" invisible="1"/>

                <footer>
                    <button string="Generate"
                            name="action_generate"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'choose'"/>
                    <button string="Close"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="action_generate_wizard" model="ir.actions.act_window">
        <field name="name">Generate Documents</field>
        <field name="res_model">ws.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
